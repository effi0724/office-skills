{
  "repos": [
    {
      "owner": "example-org",
      "name": "backend-service",
      "default_branch": "main",
      "alias": "backend"
    },
    {
      "owner": "example-org",
      "name": "frontend-app",
      "default_branch": "main",
      "alias": "frontend",
      "filters": {
        "include_paths": [
          "apps/web/**",
          "docs/**"
        ]
      }
    }
  ],
  "range": {
    "mode": "current_week",
    "start": "",
    "end": "",
    "base_sha": "",
    "head_sha": ""
  },
  "filters": {
    "authors": [],
    "include_paths": [],
    "exclude_paths": [],
    "exclude_merge_commits": true
  },
  "report": {
    "language": "zh-CN",
    "style": "manager",
    "output_dir": "outputs"
  }
}
